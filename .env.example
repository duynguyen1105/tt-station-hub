# === Database (Supabase Postgres) ===
# Pooled connection used by the app at runtime.
DATABASE_URL=
# Direct (non-pooled) connection used by Prisma migrations.
DIRECT_URL=

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
STORAGE_BUCKET=station-photos

# === AI Vision (Anthropic) ===
ANTHROPIC_API_KEY=

# === Zalo OA ===
ZALO_OA_APP_ID=
ZALO_OA_APP_SECRET=            # dev app secret — used to exchange/refresh OA tokens
ZALO_OA_ACCESS_TOKEN=          # optional fallback; normally stored+refreshed in the DB
ZALO_OA_WEBHOOK_SECRET=        # OA Secret Key — verifies webhook signatures
ZALO_AUTO_REPLY=false          # OA auto-reply "đã nhận ảnh" (needs a PAID OA tier; -224 on free)

# === Cron / scheduled tasks ===
CRON_SECRET=

# === Mock modes (develop without real Zalo / API key) ===
AI_MOCK=false
ZALO_MOCK=false
